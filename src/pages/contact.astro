---
import Layout from "../layouts/Layout.astro";

const contactFaqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: [
    {
      "@type": "Question",
      name: "How can I contact Austin Core Legal?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "You can contact Austin Core Legal by email at info@austincorelegal.com.au or by phone on 0481 225-870.",
      },
    },
    {
      "@type": "Question",
      name: "Where are Austin Core Legal offices located?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Austin Core Legal offers appointments in Sydney at Suite 10 Level 3, 88 Pitt Street, Sydney NSW 2000, and in Melbourne at Suite 42, 139 Cardigan St, Carlton VIC 3053.",
      },
    },
    {
      "@type": "Question",
      name: "Do I need an appointment before visiting?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Yes, both Sydney and Melbourne consultations are available by appointment.",
      },
    },
  ],
};
---

<Layout
  title="Contact Us | Austin Core Legal"
  description="Contact Austin Core Legal in Sydney or Melbourne"
  structuredData={contactFaqSchema}
>
  <section class="pt-32 pb-24 bg-brand-blue-pale min-h-[70vh]">
    <div class="max-w-4xl mx-auto px-6 lg:px-8">
      <div class="text-center mb-16">
        <h1
          class="text-4xl md:text-5xl font-serif font-medium text-brand-blue-deep mb-4"
        >
          Get in Touch
        </h1>
        <div class="h-1 w-24 bg-brand-blue mx-auto mb-8"></div>
        <p
          class="text-brand-text-light text-lg font-light leading-relaxed max-w-2xl mx-auto"
        >
          We are happy to assist you with your legal needs. Reach out to us via
          email, phone, or visit our offices by appointment.
        </p>
      </div>

      <div
        class="grid md:grid-cols-2 gap-12 bg-white p-10 rounded-xl shadow-sm border border-slate-100"
      >
        <!-- Contact Info -->
        <div>
          <h2 class="text-2xl font-serif text-brand-blue-deep mb-6">
            Contact Information
          </h2>
          <ul class="space-y-6">
            <li class="flex items-start">
              <span class="text-brand-blue-deep mr-4 mt-1">
                <svg
                  class="w-6 h-6"
                  fill="none"
                  stroke="currentColor"
                  viewBox="0 0 24 24"
                  ><path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"
                  ></path>
                </svg>
              </span>
              <div>
                <p class="text-sm text-brand-text-light font-medium mb-1">
                  Email
                </p>
                <a
                  href="mailto:info@austincorelegal.com.au"
                  class="text-lg text-brand-blue-deep hover:text-brand-blue transition-colors"
                  >info@austincorelegal.com.au</a
                >
              </div>
            </li>
            <li class="flex items-start">
              <span class="text-brand-blue-deep mr-4 mt-1">
                <svg
                  class="w-6 h-6"
                  fill="none"
                  stroke="currentColor"
                  viewBox="0 0 24 24"
                  ><path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"
                  ></path>
                </svg>
              </span>
              <div>
                <p class="text-sm text-brand-text-light font-medium mb-1">
                  Phone
                </p>
                <a
                  href="tel:0481225870"
                  class="text-lg text-brand-blue-deep hover:text-brand-blue transition-colors"
                  >0481 225-870</a
                >
              </div>
            </li>
          </ul>
        </div>

        <!-- Locations -->
        <div>
          <h2 class="text-2xl font-serif text-brand-blue-deep mb-6">
            Our Offices
          </h2>
          <div class="space-y-8">
            <div>
              <p
                class="font-medium text-brand-blue-deep mb-2 flex items-center gap-2"
              >
                <svg
                  class="w-5 h-5 text-brand-blue"
                  fill="none"
                  stroke="currentColor"
                  viewBox="0 0 24 24"
                  ><path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"
                  ></path><path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
                </svg>
                Sydney (By Appointment)
              </p>
              <p class="text-brand-text-light text-sm leading-relaxed mb-2">
                Suite 10 Level 3, 88 Pitt Street<br />Sydney NSW 2000
              </p>
              <p class="text-brand-text-light text-sm leading-relaxed">
                <strong class="font-medium">Mail Address:</strong><br />PO Box
                3333, St Pauls NSW 2031
              </p>
            </div>
            <div>
              <p
                class="font-medium text-brand-blue-deep mb-2 flex items-center gap-2"
              >
                <svg
                  class="w-5 h-5 text-brand-blue"
                  fill="none"
                  stroke="currentColor"
                  viewBox="0 0 24 24"
                  ><path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"
                  ></path><path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
                </svg>
                Melbourne (By Appointment)
              </p>
              <p class="text-brand-text-light text-sm leading-relaxed">
                Suite 42, 139 Cardigan St<br />Carlton VIC 3053
              </p>
            </div>
          </div>
        </div>
      </div>

      <!-- Google Maps Integration -->
      <div
        class="mt-16 bg-white p-4 rounded-xl shadow-sm border border-slate-100 h-[400px] w-full overflow-hidden"
      >
        <iframe
          src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3312.9216091873133!2d151.206233575704!3d-33.86591742445837!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x6b12ae427137f61b%3A0xe13c6b22c7a6e13b!2s88%20Pitt%20St%2C%20Sydney%20NSW%202000%2C%20Australia!5e0!3m2!1sen!2sus!4v1700000000000!5m2!1sen!2sus"
          width="100%"
          height="100%"
          style="border:0; border-radius: 0.5rem;"
          allowfullscreen=""
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
        >
        </iframe>
      </div>

      <section class="mt-16 bg-white p-10 rounded-xl shadow-sm border border-slate-100">
        <h2 class="text-3xl font-serif text-brand-blue-deep mb-8">
          Contact FAQs
        </h2>
        <div class="space-y-6">
          <div>
            <h3 class="text-xl font-serif text-brand-blue-deep mb-2">
              How can I contact Austin Core Legal?
            </h3>
            <p class="text-brand-text-light leading-relaxed">
              You can contact Austin Core Legal by email at
              <a
                href="mailto:info@austincorelegal.com.au"
                class="text-brand-blue-deep hover:text-brand-blue"
              >
                info@austincorelegal.com.au
              </a>
              or by phone on
              <a
                href="tel:0481225870"
                class="text-brand-blue-deep hover:text-brand-blue"
              >
                0481 225-870
              </a>.
            </p>
          </div>
          <div>
            <h3 class="text-xl font-serif text-brand-blue-deep mb-2">
              Where are Austin Core Legal offices located?
            </h3>
            <p class="text-brand-text-light leading-relaxed">
              Appointments are available in Sydney at Suite 10 Level 3, 88 Pitt
              Street, Sydney NSW 2000, and in Melbourne at Suite 42, 139
              Cardigan St, Carlton VIC 3053.
            </p>
          </div>
          <div>
            <h3 class="text-xl font-serif text-brand-blue-deep mb-2">
              Do I need an appointment before visiting?
            </h3>
            <p class="text-brand-text-light leading-relaxed">
              Yes, both Sydney and Melbourne consultations are available by
              appointment.
            </p>
          </div>
        </div>
      </section>
    </div>
  </section>
</Layout>
