---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const posts = await getCollection('blog');
const sortedPosts = posts.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<Layout title="Blog" description="Insights, news, and practical legal advice from Austin Core Legal." type="website">
  <section class="max-w-5xl mx-auto px-6 py-16">
    <div class="mb-12">
      <h1 class="font-serif text-4xl md:text-5xl text-brand-navy mb-4">Blog</h1>
      <p class="text-brand-gray text-lg max-w-2xl">Practical legal insights and commentary from our team to help protect your business and personal interests.</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      {sortedPosts.map((post) => (
        <a href={`/blog/${post.slug}`} class="group flex flex-col bg-white border border-slate-100 rounded-xl overflow-hidden shadow-sm hover:shadow-xl transition-all duration-300">
          {post.data.image && (
            <div class="aspect-[16/9] w-full overflow-hidden bg-slate-100">
              <img src={post.data.image} alt={post.data.title} class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105" />
            </div>
          )}
          <div class="p-6 flex flex-col flex-grow">
            <div class="flex items-center gap-2 text-sm text-brand-gray/80 mb-3">
              <time datetime={post.data.date.toISOString()}>
                {post.data.date.toLocaleDateString('en-AU', {
                  year: 'numeric',
                  month: 'long',
                  day: 'numeric',
                })}
              </time>
              {post.data.tags.length > 0 && (
                <>
                  <span aria-hidden="true">&middot;</span>
                  <span class="text-brand-gold font-medium">{post.data.tags[0]}</span>
                </>
              )}
            </div>
            
            <h2 class="text-xl font-serif text-brand-navy font-semibold mb-3 group-hover:text-brand-gold transition-colors line-clamp-2">
              {post.data.title}
            </h2>
            
            <p class="text-brand-gray text-sm leading-relaxed mb-6 line-clamp-3">
              {post.data.description}
            </p>

            <div class="mt-auto flex items-center justify-between text-sm font-medium">
              <span class="text-brand-navy group-hover:text-brand-gold transition-colors">Read article</span>
              <svg class="w-4 h-4 text-brand-gold transform group-hover:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"/></svg>
            </div>
          </div>
        </a>
      ))}
      
      {sortedPosts.length === 0 && (
        <div class="col-span-full py-20 text-center">
          <p class="text-brand-gray text-lg">No blog posts found. Check back later for practical insights.</p>
        </div>
      )}
    </div>
  </section>
</Layout>
